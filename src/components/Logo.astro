---
interface Props {
  class?: string;
  width?: number;
  height?: number;
}

const { class: className, width = 40, height = 40 } = Astro.props;
---

<span class:list={['logo-wrap', className]} style={`width:${width}px;height:${height}px`}>
  <img
    src="/logo.svg"
    alt=""
    class="logo-mark"
    width={width}
    height={height}
    decoding="async"
    aria-hidden="true"
  />
</span>
