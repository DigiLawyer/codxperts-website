---
const path = Astro.url.pathname;
const onHome = path === '/' || path === '';
const section = (id: string) => (onHome ? `#${id}` : `/#${id}`);
---
<nav id="site-nav" class="site-nav" aria-label="Primary">
  <div class="site-nav-links">
    <a href={section('clients')} class="navlink">Clients</a>
    <a href={section('partners')} class="navlink">Partners</a>
    <a href={section('capabilities')} class="navlink">Capabilities</a>
    <a href={section('work')} class="navlink">Work</a>
    <a href="/team" class:list={['navlink', { 'navlink-active': path === '/team' }]}>Team</a>
    <a href="/track-record" class:list={['navlink', { 'navlink-active': path === '/track-record' }]}>Track record</a>
    <a href={section('about')} class="navlink">About</a>
  </div>
  <a href={section('contact')} class="cta nav-cta">Start a project</a>
</nav>
