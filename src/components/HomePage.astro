---
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';

const clients = {
  government: [
    { badge: 'DR', name: 'Drug Regulatory Authority of Pakistan' },
    { badge: 'AG', name: 'Advocate General Office Punjab' },
    { badge: 'AG', name: 'Advocate General Office Sindh' },
    { badge: 'PP', name: 'Power Planning' },
  ],
  judiciary: [
    { badge: 'SH', name: 'Sindh High Court' },
    { badge: 'PH', name: 'Peshawar High Court' },
    { badge: 'PB', name: 'Govt of Punjab' },
  ],
  enforcement: [{ badge: 'SP', name: 'Sindh Police' }],
  firms: [
    { badge: 'AU', name: 'AUC Law' },
    { badge: 'AB', name: 'ABS & Co' },
    { badge: 'ZK', name: 'Zafar Kalanauri & Co' },
  ],
};
---
<SiteHeader />

<main id="main">

  <section class="hero" aria-labelledby="hero-heading">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">Software &amp; AI engineering</p>
        <h1 id="hero-heading" class="reveal">We build AI software for institutions that can't afford for it to <em>break</em>.</h1>
        <p class="lede reveal">Codxperts is trusted by <strong>courts, government regulators, and law firms</strong>. We built DigiLawyer, Pakistan's first AI legal platform, and ship applied-AI software for clients worldwide.</p>
        <div class="hero-actions reveal">
          <a href="#contact" class="btn btn-primary">Start a project <span class="arr" aria-hidden="true">&rarr;</span></a>
          <a href="#work" class="btn btn-ghost">See the work</a>
        </div>
        <p class="hero-portfolio reveal">
          <a href="https://oboxks3wp0.ufs.sh/f/iW0yAF6rEygJXuhjk3vGakUrTPICen4zvidYDEmZAfwS139W" class="portfolio-link" download="codxperts-portfolio.pdf">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download portfolio PDF
          </a>
        </p>
      </div>

      <aside class="panel reveal" aria-labelledby="docket-heading">
        <div class="panel-head">
          <h2 id="docket-heading" class="t">Institutional deployments</h2>
          <span class="live"><span class="d" aria-hidden="true"></span>In production</span>
        </div>
        <div class="stagger">
          <div class="prow"><span class="cat">Regulator</span><span class="who">Drug Regulatory Authority (DRAP)</span></div>
          <div class="prow"><span class="cat">Judiciary</span><span class="who">Sindh High Court</span></div>
          <div class="prow"><span class="cat">Judiciary</span><span class="who">Peshawar High Court</span></div>
          <div class="prow"><span class="cat">Government</span><span class="who">Advocate General offices</span></div>
          <div class="prow"><span class="cat">Law firm</span><span class="who">Zafar Kalanauri &amp; Co</span></div>
        </div>
        <p class="panel-foot">Software in daily use across the public and private sector.</p>
      </aside>
    </div>
  </section>

  <section id="clients" class="section-anchor">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          <p class="eyebrow">Clients</p>
          <h2>Trusted across the public and private sector.</h2>
        </div>
      </div>

      <div class="client-block reveal">
        <div class="cgroup">
          <div class="label"><div class="k">Government &amp; regulators</div></div>
          <div class="names">
            {clients.government.map((c) => (
              <div class="nm">
                <span class="nm-badge" aria-hidden="true">{c.badge}</span>
                {c.name}
              </div>
            ))}
          </div>
        </div>

        <div class="cgroup">
          <div class="label"><div class="k">Judiciary</div></div>
          <div class="names">
            {clients.judiciary.map((c) => (
              <div class="nm">
                <span class="nm-badge" aria-hidden="true">{c.badge}</span>
                {c.name}
              </div>
            ))}
          </div>
        </div>

        <div class="cgroup">
          <div class="label"><div class="k">Law enforcement</div></div>
          <div class="names">
            {clients.enforcement.map((c) => (
              <div class="nm">
                <span class="nm-badge" aria-hidden="true">{c.badge}</span>
                {c.name}
              </div>
            ))}
          </div>
        </div>

        <div class="cgroup">
          <div class="label"><div class="k">Law firms</div></div>
          <div class="names">
            {clients.firms.map((c) => (
              <div class="nm">
                <span class="nm-badge" aria-hidden="true">{c.badge}</span>
                {c.name}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="partners" class="section-anchor">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          <p class="eyebrow">Partners &amp; programs</p>
          <h2>Backed by the infrastructure we build on.</h2>
        </div>
      </div>

      <div class="prog-grid reveal">
        <div class="prog">
          <div class="prog-logo" aria-label="Google">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z" fill="#4285F4"/>
            </svg>
          </div>
          <div class="pname">Google for Startups</div>
          <div class="porg">Cloud Program</div>
          <p class="pdesc">Selected for Google's program for high-growth startups. Cloud and AI infrastructure backing our build, including a $75K grant.</p>
        </div>
        <div class="prog">
          <div class="prog-logo" aria-label="Anthropic">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
              <path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.5409Zm-.3712 10.2232 2.2914-5.9456 2.2914 5.9456Z" fill="#C96442"/>
            </svg>
          </div>
          <div class="pname">Claude Partner Network</div>
          <div class="porg">Anthropic</div>
          <p class="pdesc">Building production AI on Anthropic's Claude models as a recognized partner in the Claude ecosystem.</p>
        </div>
        <div class="prog">
          <div class="prog-logo" aria-label="NVIDIA">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
              <path d="M8.948 8.798v-1.43a6.7 6.7 0 0 1 .424-.018c3.922-.124 6.493 3.374 6.493 3.374s-2.774 3.851-5.75 3.851c-.398 0-.787-.062-1.158-.185v-4.346c1.528.185 1.837.857 2.747 2.385l2.04-1.714s-1.492-1.952-4-1.952a6.016 6.016 0 0 0-.796.035m0-4.735v2.138l.424-.027c5.45-.185 9.01 4.47 9.01 4.47s-4.08 4.964-8.33 4.964c-.37 0-.733-.035-1.095-.097v1.325c.3.035.61.062.91.062 3.957 0 6.82-2.023 9.593-4.408.459.371 2.34 1.263 2.73 1.652-2.633 2.208-8.772 3.984-12.253 3.984-.335 0-.653-.018-.971-.053v1.864H24V4.063zm0 10.326v1.131c-3.657-.654-4.673-4.46-4.673-4.46s1.758-1.944 4.673-2.262v1.237H8.94c-1.528-.186-2.73 1.245-2.73 1.245s.68 2.412 2.739 3.11M2.456 10.9s2.164-3.197 6.5-3.533V6.201C4.153 6.59 0 10.653 0 10.653s2.35 6.802 8.948 7.42v-1.237c-4.84-.6-6.492-5.936-6.492-5.936z" fill="#76B900"/>
            </svg>
          </div>
          <div class="pname">NVIDIA Inception</div>
          <div class="porg">NVIDIA</div>
          <p class="pdesc">Member of NVIDIA's global program for AI startups with access to compute resources and technical support.</p>
        </div>
      </div>

      <div class="group-bar reveal">
        <span class="gtag">Group company</span>
        <div>
          <span class="gname">DevBazar</span>
          <p class="gdesc">Technical recruitment and talent placement. We help engineering teams hire.</p>
        </div>
        <a class="btn btn-ghost" href="#contact">Talk to DevBazar <span class="arr">&rarr;</span></a>
      </div>
    </div>
  </section>

  <section id="capabilities" class="section-anchor">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          <p class="eyebrow">What we do</p>
          <h2>Full-stack software, applied AI, and the hard parts in between.</h2>
        </div>
      </div>
      <div class="cap-grid reveal">
        <div class="cap">
          <span class="cap-tag">Applied AI</span>
          <h3>Applied AI &amp; LLM systems</h3>
          <p>RAG, agents, domain copilots, evals, and fine-tuning. Shipped into precision-critical domains including legal, compliance, and research.</p>
          <div class="stack"><span>RAG</span><span>Agents</span><span>Evals</span><span>Fine-tuning</span></div>
        </div>
        <div class="cap">
          <span class="cap-tag">Product</span>
          <h3>Product engineering, zero to scale</h3>
          <p>Full-stack product from first commit to thousands of users. Clean architecture, real design systems, and the discipline to ship without the rebuild.</p>
          <div class="stack"><span>Next.js</span><span>FastAPI</span><span>NestJS</span><span>TypeScript</span></div>
        </div>
        <div class="cap">
          <span class="cap-tag">Data</span>
          <h3>Data, search &amp; automation</h3>
          <p>ETL pipelines, document corpora, citation graphs, scraping and multi-source integrations. We move, clean, and make sense of data at scale.</p>
          <div class="stack"><span>Pipelines</span><span>Search relevance</span><span>Scraping</span><span>Integrations</span></div>
        </div>
        <div class="cap">
          <span class="cap-tag">Platforms</span>
          <h3>Aggregators &amp; marketplaces</h3>
          <p>Multi-source platforms querying, normalizing, and unifying APIs behind one experience, with admin tooling for pricing, rules, and reporting.</p>
          <div class="stack"><span>API aggregation</span><span>Admin panels</span><span>Supabase</span><span>Vercel</span></div>
        </div>
      </div>
      <div class="industries reveal">
        <span class="il">Industries</span>
        <span class="it">Legal</span><span class="sep">/</span>
        <span class="it">Travel</span><span class="sep">/</span>
        <span class="it">Healthcare</span><span class="sep">/</span>
        <span class="it">E-commerce</span><span class="sep">/</span>
        <span class="it">EdTech</span><span class="sep">/</span>
        <span class="it">Fintech &amp; loyalty</span><span class="sep">/</span>
        <span class="it">SaaS</span><span class="sep">/</span>
        <span class="it">Data &amp; AI</span>
      </div>
    </div>
  </section>

  <section id="work" class="section-anchor">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2>Built, shipped, in use.</h2>
        </div>
      </div>

      <article class="case reveal">
        <div class="case-top">
          <div><span class="tag">Flagship product &middot; Legal AI</span><h3>DigiLawyer</h3></div>
          <div class="role">Product, design,<br>engineering, AI<br>2022 to present</div>
        </div>
        <div class="case-body">
          <div>
            <p>Pakistan's legal record was scattered, unsearchable, and locked in PDFs. <strong>We built the platform that makes it usable.</strong> DigiLawyer indexes 52 legal journals into a connected research system with citation intelligence, judgment search, and AI assistants for research and drafting.</p>
            <p>From empty repository to <strong>20,000+ users, paying subscribers, and institutional partnerships across the judiciary, government, and law enforcement.</strong></p>
          </div>
          <div class="metrics">
            <div class="m"><div class="v">20k+</div><div class="l">Users</div></div>
            <div class="m"><div class="v">52</div><div class="l">Journals indexed</div></div>
            <div class="m"><div class="v">3+</div><div class="l">Gov partners</div></div>
            <div class="m"><div class="v">2</div><div class="l">AI assistants</div></div>
          </div>
        </div>
        <div class="case-foot">
          <span><b>Stack:</b> Next.js &middot; tRPC &middot; TypeScript &middot; PostHog</span>
          <span><b>AI:</b> retrieval &middot; citation graph &middot; drafting</span>
          <span><b>Status:</b> live and growing</span>
        </div>
      </article>

      <article class="case reveal">
        <div class="case-top">
          <div><span class="tag">Travel &middot; Aggregation</span><h3>Tracksure Connect</h3></div>
          <div class="role">Backend + full-stack<br>Sep to Oct 2025</div>
        </div>
        <div class="case-body">
          <div>
            <p>Smaller South Asian airlines don't appear on mainstream booking platforms. <strong>A flight search and booking engine built specifically for them.</strong></p>
            <p>Queries multiple airline APIs concurrently with async calls, normalizes and aggregates results, applies admin-defined pricing and filtering rules, and returns one unified search experience. Full admin panel for reporting and rule management.</p>
          </div>
          <div class="metrics">
            <div class="m"><div class="v">Async</div><div class="l">Concurrent API calls</div></div>
            <div class="m"><div class="v">Unified</div><div class="l">One search, many carriers</div></div>
            <div class="m"><div class="v">Rules</div><div class="l">Admin pricing + filters</div></div>
            <div class="m"><div class="v">Live</div><div class="l">Deployed on Vercel</div></div>
          </div>
        </div>
        <div class="case-foot">
          <span><b>Stack:</b> FastAPI &middot; Next.js &middot; Supabase &middot; Vercel</span>
          <span><b>Focus:</b> API aggregation &middot; admin tooling</span>
        </div>
      </article>

      <article class="case reveal">
        <div class="case-top">
          <div><span class="tag">AI &middot; Legal-tech</span><h3>MyContract</h3></div>
          <div class="role">AI + full-stack<br>Nov 2024 to Mar 2025</div>
        </div>
        <div class="case-body">
          <div>
            <p>AI-assisted contract intelligence: generation, review, and compliance checking against government and organizational regulations.</p>
            <p>Built on LLMs that parse legal language, flag non-compliant clauses, and generate draft contracts aligned to applicable codes. <strong>Adopted into DigiLawyer's core product as the Mike AI Draft feature</strong>, one of the few projects that shipped into a production legal-tech platform.</p>
          </div>
          <div class="metrics">
            <div class="m"><div class="v">LLM</div><div class="l">Parses legal language</div></div>
            <div class="m"><div class="v">Flags</div><div class="l">Non-compliant clauses</div></div>
            <div class="m"><div class="v">Drafts</div><div class="l">Code-aligned contracts</div></div>
            <div class="m"><div class="v">Shipped</div><div class="l">Became Mike AI Draft</div></div>
          </div>
        </div>
        <div class="case-foot">
          <span><b>Focus:</b> Applied LLMs &middot; compliance &middot; document generation</span>
          <span><b>Outcome:</b> productionized in DigiLawyer</span>
        </div>
      </article>

      <p class="more-head reveal">More builds</p>
      <div class="more-grid reveal">
        <div class="mb">
          <div class="yr">2022</div>
          <h4>SecondBite, OC Store ETL</h4>
          <p>Full ETL and automation pipeline for an OpenCart store. Scrapes product data from multiple sources, cleans and normalizes it, match-checks against inventory, and syncs new or updated entries. Google Sheets as client-facing control surface.</p>
          <div class="stack"><span>Python</span><span>Selenium</span><span>Pandas</span><span>Sheets API</span></div>
        </div>
        <div class="mb">
          <div class="yr">2024</div>
          <h4>Graph-Based Text Classifier</h4>
          <p>Scrapes Medium articles across user-chosen topics via GraphQL, converts them to graph structures, runs network analysis including spanning trees and centrality metrics, visualizes with Gravis. NLP meets graph theory.</p>
          <div class="stack"><span>NLP</span><span>Graph theory</span><span>GraphQL</span><span>Gravis</span></div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="section-anchor">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          <p class="eyebrow">Who we are</p>
          <h2>A firm that ships its own products.</h2>
        </div>
      </div>
      <div class="about-grid">
        <div class="reveal">
          <p>Codxperts isn't an agency that learned to build by billing hours. <strong>We're product builders first.</strong> We built DigiLawyer ourselves, took it to scale, and shipped it into institutions that don't tolerate software that breaks.</p>
          <p>We bring that same engineering to client work, across legal, travel, healthcare, and commerce. <strong>Based in Lahore. Building for teams worldwide.</strong></p>
        </div>
        <div class="creds reveal">
          <div class="cred"><span class="cy">VC</span><span class="cx">Investor-backed<small>institutional investment</small></span></div>
          <div class="cred"><span class="cy">2026</span><span class="cx">Google grant recipient<small>$75K cloud + AI credits</small></span></div>
          <div class="cred"><span class="cy">2024</span><span class="cx">Shark Tank Pakistan<small>televised investment round</small></span></div>
          <div class="cred"><span class="cy">GROUP</span><span class="cx">DevBazar<small>recruitment &amp; talent</small></span></div>
        </div>
      </div>

      <p class="about-cta reveal">
        <a href="/track-record" class="btn about-cta-btn">View track record <span class="arr">&rarr;</span></a>
      </p>
    </div>
  </section>

  <section id="contact" class="section-anchor contact-section">
    <div class="wrap">
      <p class="eyebrow reveal">Start a project</p>
      <div class="contact-grid reveal">
        <div>
          <h2>Have something hard to build?</h2>
          <p class="contact-email"><a href="mailto:hello@codxperts.com">hello@codxperts.com</a></p>
          <p class="sub">Tell us what you're building and where it's stuck. We reply to every real inquiry.</p>
        </div>
        <a href="mailto:hello@codxperts.com" class="btn btn-primary">Send a brief <span class="arr">&rarr;</span></a>
      </div>
    </div>
  </section>

</main>

<SiteFooter />
