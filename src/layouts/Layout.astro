---
import '../styles/global.css';
import { uploadedAssets } from '../data/uploaded-assets';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Codxperts — Software & AI engineering',
  description = "Codxperts builds software and AI products trusted by courts, government offices, regulators, and law firms. The team behind DigiLawyer. Building globally.",
  image = uploadedAssets.site.ogImagePng,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href={uploadedAssets.site.faviconIco} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={uploadedAssets.site.faviconSvg} />
    <link rel="icon" type="image/png" sizes="32x32" href={uploadedAssets.site.favicon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={uploadedAssets.site.favicon16} />
    <link rel="apple-touch-icon" sizes="180x180" href={uploadedAssets.site.appleTouchIcon} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#15171C" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Codxperts" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Codxperts — Software and AI engineering" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content="Codxperts — Software and AI engineering" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Archivo+Expanded:wght@600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <script is:inline src="/reveal.js"></script>
    <script is:inline src="/nav.js"></script>
  </body>
</html>
